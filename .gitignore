# === WordPress Core Files (should never be in git) ===
/xmlrpc.php
/wp-config.php
/.htaccess

# === Composer & Node Dependencies ===
/node_modules/
/vendor/
/build/
v8-compile-cache-0/
/package-lock.json

# === Logs and Environment Files ===
*.log
*.bak
*.swp
*.swo
*.tmp
*.cache
.env
.env.*  # .env.local, .env.production, etc.

# === macOS System Files ===
.DS_Store
.AppleDouble
.LSOverride
._*

# === Windows System Files ===
Thumbs.db
ehthumbs.db
Desktop.ini

# === Linux System Files ===
*~

# === IDE / Editor Files ===
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# === Version Control Directories ===
.svn/
.cvs/

# === Optional: Ignore Database and Export Files ===
*.sql
*.sql.gz
*.zip

# === Optional: Ignore Custom Cache and Debug Folders ===
cache/
debug.log
/wp-content/cache/
/wp-content/backups/

# === Ignore Lock Files if Not Using for Deployment ===
package-lock.json
yarn.lock
composer.lock